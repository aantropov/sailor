<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Name="this"
             x:Class="SailorEditor.Views.SceneView">

    <Grid>
        <Border x:Name="Viewport"
                BackgroundColor="#111111"
                Stroke="#2A2A2A"
                StrokeThickness="1"
                Padding="0">
            <Grid>
                <ContentView x:Name="NativeViewportContainer"
                             HorizontalOptions="Fill"
                             VerticalOptions="Fill" />

                <Border x:Name="ViewportStatusOverlay"
                        StrokeThickness="1"
                        Stroke="#3A3A3A"
                        BackgroundColor="#CC111111"
                        Padding="12"
                        HorizontalOptions="Start"
                        VerticalOptions="Start"
                        Margin="12"
                        MaximumWidthRequest="520">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Remote viewport"
                               FontAttributes="Bold"
                               TextColor="White" />
                        <Label x:Name="ViewportStatusText"
                               Text="Starting…"
                               FontAttributes="Bold"
                               TextColor="#D0D0D0" />
                        <Label x:Name="ViewportTruthText"
                               Text="Analyzing frame feed…"
                               FontAttributes="Bold"
                               TextColor="#FFD166" />
                        <Label x:Name="ViewportSourceText"
                               Text="Source: pending"
                               FontSize="12"
                               LineBreakMode="WordWrap"
                               TextColor="#E6E6E6" />
                        <Label x:Name="ViewportEvidenceText"
                               Text="Evidence: pending"
                               FontSize="12"
                               LineBreakMode="WordWrap"
                               TextColor="#D8D8D8" />
                        <Label x:Name="ViewportGeometryText"
                               Text="Viewport: pending"
                               FontSize="12"
                               LineBreakMode="WordWrap"
                               TextColor="#C8C8C8" />
                        <Label x:Name="ViewportSamplesText"
                               Text="Samples: pending"
                               FontSize="12"
                               LineBreakMode="WordWrap"
                               TextColor="#B8D8FF" />
                        <Label x:Name="ViewportProbeText"
                               Text="Probe: pending"
                               FontSize="11"
                               LineBreakMode="WordWrap"
                               MaxLines="3"
                               TextColor="#9FC2FF" />
                        <Label x:Name="ViewportDiagnosticsText"
                               Text=""
                               FontSize="11"
                               LineBreakMode="WordWrap"
                               MaxLines="8"
                               TextColor="#A8A8A8" />
                        <Button x:Name="RetryRemoteViewportButton"
                                Text="Retry"
                                IsVisible="False"
                                Clicked="OnRetryRemoteViewportClicked" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Border>
    </Grid>
</ContentView>
