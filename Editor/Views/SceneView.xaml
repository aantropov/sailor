<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Name="this"
             x:Class="SailorEditor.Views.SceneView">

    <Grid>
        <Border x:Name="Viewport"
                BackgroundColor="#111111"
                Stroke="#2A2A2A"
                StrokeThickness="1"
                Padding="0">
            <Grid>
                <ContentView x:Name="NativeViewportContainer" />

                <Border x:Name="ViewportStatusOverlay"
                        StrokeThickness="1"
                        Stroke="#3A3A3A"
                        BackgroundColor="#AA111111"
                        Padding="12"
                        HorizontalOptions="Start"
                        VerticalOptions="Start"
                        Margin="12">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Remote viewport"
                               FontAttributes="Bold"
                               TextColor="White" />
                        <Label x:Name="ViewportStatusText"
                               Text="Starting…"
                               TextColor="#D0D0D0" />
                        <Label x:Name="ViewportDiagnosticsText"
                               Text=""
                               FontSize="11"
                               LineBreakMode="WordWrap"
                               MaxLines="4"
                               TextColor="#A8A8A8" />
                        <Button x:Name="RetryRemoteViewportButton"
                                Text="Retry"
                                IsVisible="False"
                                Clicked="OnRetryRemoteViewportClicked" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Border>
    </Grid>
</ContentView>
