<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Name="this"
             x:Class="SailorEditor.Views.ToolbarView">

    <ContentView.Resources>
        <Style x:Key="ToolbarIconButtonStyle" TargetType="ImageButton">
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="BorderWidth" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HeightRequest" Value="16"/>
            <Setter Property="WidthRequest" Value="16"/>
            <Setter Property="MinimumHeightRequest" Value="16"/>
            <Setter Property="MinimumWidthRequest" Value="16"/>
            <Setter Property="Aspect" Value="AspectFit"/>
            <Setter Property="HorizontalOptions" Value="Center"/>
            <Setter Property="VerticalOptions" Value="Center"/>
        </Style>

        <Style x:Key="ToolbarGlyphButtonStyle" TargetType="Button">
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="BorderWidth" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="WidthRequest" Value="18"/>
            <Setter Property="HeightRequest" Value="18"/>
            <Setter Property="MinimumWidthRequest" Value="18"/>
            <Setter Property="MinimumHeightRequest" Value="18"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextColor" Value="#D8D8D8"/>
        </Style>
    </ContentView.Resources>

    <Border StrokeThickness="1"
            Stroke="#35363A"
            BackgroundColor="#202124"
            Padding="8,4"
            Margin="0"
            MinimumHeightRequest="28"
            StrokeShape="RoundRectangle 0">
        <Grid ColumnSpacing="10"
              RowSpacing="0"
              Margin="0"
              Padding="0"
              HeightRequest="20"
              VerticalOptions="Center"
              HorizontalOptions="FillAndExpand">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    StrokeThickness="1"
                    Stroke="#2B2C30"
                    BackgroundColor="#252629"
                    Padding="6,2"
                    StrokeShape="RoundRectangle 4">
                <ImageButton Source="disk_24.png"
                             Style="{StaticResource ToolbarIconButtonStyle}"
                             Clicked="OnSaveButtonClicked"/>
            </Border>

            <HorizontalStackLayout Grid.Column="1"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   Spacing="6">
                <Border StrokeThickness="1"
                        Stroke="#2B2C30"
                        BackgroundColor="#252629"
                        Padding="6,2"
                        StrokeShape="RoundRectangle 4">
                    <HorizontalStackLayout Spacing="6">
                        <Button Text="↶"
                                Style="{StaticResource ToolbarGlyphButtonStyle}"
                                Clicked="OnUndoButtonClicked"/>
                        <Button Text="↷"
                                Style="{StaticResource ToolbarGlyphButtonStyle}"
                                Clicked="OnRedoButtonClicked"/>
                    </HorizontalStackLayout>
                </Border>

                <Border StrokeThickness="1"
                        Stroke="#2B2C30"
                        BackgroundColor="#252629"
                        Padding="6,2"
                        StrokeShape="RoundRectangle 4">
                    <HorizontalStackLayout Spacing="6">
                        <ImageButton Source="arrow_24.png"
                                     Style="{StaticResource ToolbarIconButtonStyle}"
                                     Clicked="OnPlayButtonClicked"/>
                        <ImageButton Source="bug__arrow.png"
                                     Style="{StaticResource ToolbarIconButtonStyle}"
                                     Clicked="OnPlayDebugButtonClicked"/>
                    </HorizontalStackLayout>
                </Border>
            </HorizontalStackLayout>

            <Border Grid.Column="2"
                    StrokeThickness="1"
                    Stroke="#2B2C30"
                    BackgroundColor="#252629"
                    Padding="6,2"
                    StrokeShape="RoundRectangle 4">
                <HorizontalStackLayout Spacing="6">
                    <ImageButton Source="application_export_24.png"
                                 Style="{StaticResource ToolbarIconButtonStyle}"
                                 Clicked="OnPathTraceSceneButtonClicked"/>

                    <ImageButton Source="application_export.png"
                                 Style="{StaticResource ToolbarIconButtonStyle}"
                                 Clicked="OnPathTraceSelectionButtonClicked"/>
                </HorizontalStackLayout>
            </Border>
        </Grid>
    </Border>

</ContentView>
