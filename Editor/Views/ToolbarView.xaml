<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Name="this"
             x:Class="SailorEditor.Views.ToolbarView">

    <ContentView.Resources>
        <Style x:Key="ToolbarIconButtonStyle" TargetType="ImageButton">
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="BorderWidth" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HeightRequest" Value="18"/>
            <Setter Property="WidthRequest" Value="18"/>
            <Setter Property="MinimumHeightRequest" Value="18"/>
            <Setter Property="MinimumWidthRequest" Value="18"/>
            <Setter Property="Aspect" Value="AspectFit"/>
            <Setter Property="HorizontalOptions" Value="Center"/>
            <Setter Property="VerticalOptions" Value="Center"/>
        </Style>

        <Style x:Key="ToolbarGlyphButtonStyle" TargetType="Button">
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="BorderWidth" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="WidthRequest" Value="22"/>
            <Setter Property="HeightRequest" Value="22"/>
            <Setter Property="MinimumWidthRequest" Value="22"/>
            <Setter Property="MinimumHeightRequest" Value="22"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextColor" Value="#CFCFD2"/>
        </Style>
    </ContentView.Resources>

    <Border StrokeThickness="1"
            Stroke="#363A40"
            BackgroundColor="#202328"
            Padding="8,5"
            Margin="0"
            MinimumHeightRequest="36"
            StrokeShape="RoundRectangle 0">
        <Grid ColumnSpacing="8"
              RowSpacing="0"
              Margin="0"
              Padding="0"
              HeightRequest="26"
              VerticalOptions="Center"
              HorizontalOptions="FillAndExpand">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0"
                   Text="SAILOR"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8F949C"
                   VerticalTextAlignment="Center"
                   Margin="0,0,2,0"/>

            <Border Grid.Column="1"
                    StrokeThickness="1"
                    Stroke="#3B3F46"
                    BackgroundColor="#2A2E35"
                    Padding="6,3"
                    StrokeShape="RoundRectangle 3">
                <ImageButton Source="disk_24.png"
                             Style="{StaticResource ToolbarIconButtonStyle}"
                             Clicked="OnSaveButtonClicked"/>
            </Border>

            <HorizontalStackLayout Grid.Column="2"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   Spacing="4">
                <Border StrokeThickness="1"
                        Stroke="#3B3F46"
                        BackgroundColor="#2A2E35"
                        Padding="6,3"
                        StrokeShape="RoundRectangle 3">
                    <HorizontalStackLayout Spacing="4">
                        <Button Text="↶"
                                Style="{StaticResource ToolbarGlyphButtonStyle}"
                                Clicked="OnUndoButtonClicked"/>
                        <Button Text="↷"
                                Style="{StaticResource ToolbarGlyphButtonStyle}"
                                Clicked="OnRedoButtonClicked"/>
                    </HorizontalStackLayout>
                </Border>

                <Border StrokeThickness="1"
                        Stroke="#3B3F46"
                        BackgroundColor="#2A2E35"
                        Padding="6,3"
                        StrokeShape="RoundRectangle 3">
                    <HorizontalStackLayout Spacing="4">
                        <ImageButton Source="arrow_24.png"
                                     Style="{StaticResource ToolbarIconButtonStyle}"
                                     Clicked="OnPlayButtonClicked"/>
                        <ImageButton Source="bug__arrow.png"
                                     Style="{StaticResource ToolbarIconButtonStyle}"
                                     Clicked="OnPlayDebugButtonClicked"/>
                    </HorizontalStackLayout>
                </Border>
            </HorizontalStackLayout>

            <Border Grid.Column="3"
                    StrokeThickness="1"
                    Stroke="#3B3F46"
                    BackgroundColor="#2A2E35"
                    Padding="6,3"
                    StrokeShape="RoundRectangle 3">
                <HorizontalStackLayout Spacing="4">
                    <ImageButton Source="application_export_24.png"
                                 Style="{StaticResource ToolbarIconButtonStyle}"
                                 Clicked="OnPathTraceSceneButtonClicked"/>

                    <ImageButton Source="application_export.png"
                                 Style="{StaticResource ToolbarIconButtonStyle}"
                                 Clicked="OnPathTraceSelectionButtonClicked"/>
                </HorizontalStackLayout>
            </Border>

            <Border Grid.Column="4"
                    StrokeThickness="1"
                    Stroke="#3B3F46"
                    BackgroundColor="#2A2E35"
                    Padding="8,3"
                    StrokeShape="RoundRectangle 3">
                <HorizontalStackLayout Spacing="6">
                    <Button Text="Save Layout"
                            Style="{StaticResource ToolbarGlyphButtonStyle}"
                            WidthRequest="86"
                            MinimumWidthRequest="86"
                            Clicked="OnSaveLayoutButtonClicked"/>
                    <Button Text="Reset Layout"
                            Style="{StaticResource ToolbarGlyphButtonStyle}"
                            WidthRequest="92"
                            MinimumWidthRequest="92"
                            Clicked="OnResetLayoutButtonClicked"/>
                    <Button Text="Settings"
                            Style="{StaticResource ToolbarGlyphButtonStyle}"
                            WidthRequest="68"
                            MinimumWidthRequest="68"
                            Clicked="OnSettingsButtonClicked"/>
                </HorizontalStackLayout>
            </Border>
        </Grid>
    </Border>

</ContentView>
