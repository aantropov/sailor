<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Name="this"
             x:Class="SailorEditor.Views.ToolbarView">

    <ContentView.Resources>
        <Style x:Key="ToolbarIconButtonStyle" TargetType="ImageButton">
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="BorderWidth" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HeightRequest" Value="14"/>
            <Setter Property="WidthRequest" Value="14"/>
            <Setter Property="MinimumHeightRequest" Value="14"/>
            <Setter Property="MinimumWidthRequest" Value="14"/>
            <Setter Property="Aspect" Value="AspectFit"/>
            <Setter Property="HorizontalOptions" Value="Center"/>
            <Setter Property="VerticalOptions" Value="Center"/>
        </Style>

        <Style x:Key="ToolbarGlyphButtonStyle" TargetType="Button">
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="BorderWidth" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="WidthRequest" Value="16"/>
            <Setter Property="HeightRequest" Value="16"/>
            <Setter Property="MinimumWidthRequest" Value="16"/>
            <Setter Property="MinimumHeightRequest" Value="16"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextColor" Value="#CFCFD2"/>
        </Style>
    </ContentView.Resources>

    <Border StrokeThickness="1"
            Stroke="#2B2C30"
            BackgroundColor="#18191B"
            Padding="6,2"
            Margin="0"
            MinimumHeightRequest="22"
            StrokeShape="RoundRectangle 0">
        <Grid ColumnSpacing="8"
              RowSpacing="0"
              Margin="0"
              Padding="0"
              HeightRequest="16"
              VerticalOptions="Center"
              HorizontalOptions="FillAndExpand">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0"
                   Text="SAILOR"
                   FontSize="10"
                   FontAttributes="Bold"
                   TextColor="#8F949C"
                   VerticalTextAlignment="Center"
                   Margin="0,0,2,0"/>

            <Border Grid.Column="1"
                    StrokeThickness="1"
                    Stroke="#25262A"
                    BackgroundColor="#1F2023"
                    Padding="4,1"
                    StrokeShape="RoundRectangle 3">
                <ImageButton Source="disk_24.png"
                             Style="{StaticResource ToolbarIconButtonStyle}"
                             Clicked="OnSaveButtonClicked"/>
            </Border>

            <HorizontalStackLayout Grid.Column="2"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   Spacing="4">
                <Border StrokeThickness="1"
                        Stroke="#25262A"
                        BackgroundColor="#1F2023"
                        Padding="4,1"
                        StrokeShape="RoundRectangle 3">
                    <HorizontalStackLayout Spacing="4">
                        <Button Text="↶"
                                Style="{StaticResource ToolbarGlyphButtonStyle}"
                                Clicked="OnUndoButtonClicked"/>
                        <Button Text="↷"
                                Style="{StaticResource ToolbarGlyphButtonStyle}"
                                Clicked="OnRedoButtonClicked"/>
                    </HorizontalStackLayout>
                </Border>

                <Border StrokeThickness="1"
                        Stroke="#25262A"
                        BackgroundColor="#1F2023"
                        Padding="4,1"
                        StrokeShape="RoundRectangle 3">
                    <HorizontalStackLayout Spacing="4">
                        <ImageButton Source="arrow_24.png"
                                     Style="{StaticResource ToolbarIconButtonStyle}"
                                     Clicked="OnPlayButtonClicked"/>
                        <ImageButton Source="bug__arrow.png"
                                     Style="{StaticResource ToolbarIconButtonStyle}"
                                     Clicked="OnPlayDebugButtonClicked"/>
                    </HorizontalStackLayout>
                </Border>
            </HorizontalStackLayout>

            <Border Grid.Column="3"
                    StrokeThickness="1"
                    Stroke="#25262A"
                    BackgroundColor="#1F2023"
                    Padding="4,1"
                    StrokeShape="RoundRectangle 3">
                <HorizontalStackLayout Spacing="4">
                    <ImageButton Source="application_export_24.png"
                                 Style="{StaticResource ToolbarIconButtonStyle}"
                                 Clicked="OnPathTraceSceneButtonClicked"/>

                    <ImageButton Source="application_export.png"
                                 Style="{StaticResource ToolbarIconButtonStyle}"
                                 Clicked="OnPathTraceSelectionButtonClicked"/>
                </HorizontalStackLayout>
            </Border>

            <Border Grid.Column="4"
                    StrokeThickness="1"
                    Stroke="#25262A"
                    BackgroundColor="#1F2023"
                    Padding="6,1"
                    StrokeShape="RoundRectangle 3">
                <HorizontalStackLayout Spacing="6">
                    <Button Text="Panels"
                            Style="{StaticResource ToolbarGlyphButtonStyle}"
                            WidthRequest="44"
                            MinimumWidthRequest="44"
                            Clicked="OnPanelsButtonClicked"/>
                    <Button Text="Settings"
                            Style="{StaticResource ToolbarGlyphButtonStyle}"
                            WidthRequest="52"
                            MinimumWidthRequest="52"
                            Clicked="OnSettingsButtonClicked"/>
                </HorizontalStackLayout>
            </Border>
        </Grid>
    </Border>

</ContentView>
