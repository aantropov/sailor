<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Name="this"
             x:Class="SailorEditor.Views.ContentFolderView"
             xmlns:controls="clr-namespace:SailorEditor.Controls"
             xmlns:content="clr-namespace:SailorEditor.Content">

    <Frame>
        <Grid x:Name="ContentDropSurface"
              RowSpacing="0"
              ColumnSpacing="0"
              Padding="4"
              BackgroundColor="Transparent">
            <CollectionView x:Name="ContentList"
                            Margin="0,4,0,0"
                            SelectionMode="Single"
                            VerticalOptions="Fill"
                            HorizontalOptions="Fill" />
        </Grid>
    </Frame>
</ContentView>
