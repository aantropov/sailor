<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:SailorEditor"
             xmlns:views="clr-namespace:SailorEditor.Views"
             xmlns:shell="clr-namespace:SailorEditor.Shell"
             x:Class="SailorEditor.MainPage"
             x:DataType="local:MainPage"
             Title="Sailor Editor">

    <Grid RowSpacing="0" ColumnSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <views:ToolbarView Grid.Row="0"/>
        <shell:ShellLayoutView x:Name="ShellLayoutHost" Grid.Row="1"/>

        <Border Grid.Row="2" StrokeThickness="1" Stroke="DimGray" BackgroundColor="#1E1E1E" Padding="10,6">
            <VerticalStackLayout Spacing="2">
                <Grid ColumnDefinitions="Auto,*">
                    <Label Text="Status" FontAttributes="Bold" Margin="0,0,8,0"/>
                    <Label x:Name="StatusTextLabel" Grid.Column="1" Text="Ready"/>
                </Grid>
                <Label Text="Right-click a tab strip to add panels. Click a tab to focus it, × to close it, and Reset Layout if the shell gets messy."
                       FontSize="11"
                       TextColor="#90939A"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
